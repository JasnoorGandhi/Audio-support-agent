# ============================================================
# Audio Customer Support Agent — Environment Variables
# Copy this file to .env and fill in your values.
# ============================================================

# ── LLM (Required) ──────────────────────────────────────────
# Groq — https://console.groq.com/keys
GROQ_API_KEY=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
LLM_MODEL=llama-3.3-70b-versatile
LLM_TEMPERATURE=0.7

# ── STT ─────────────────────────────────────────────────────
# Provider: 'whisper' (local, free, default) | 'deepgram' | 'assemblyai'
STT_PROVIDER=whisper
# Whisper model size: tiny | base | small | medium | large
STT_MODEL=base

# Only needed for cloud providers:
# DEEPGRAM_API_KEY=your-deepgram-key
# ASSEMBLYAI_API_KEY=your-assemblyai-key
# STT_API_KEY=your-stt-key   # generic fallback

# ── TTS ─────────────────────────────────────────────────────
# Provider: 'edge_tts' (local, free, default) | 'elevenlabs' | 'openai'
TTS_PROVIDER=edge_tts
# Edge TTS voice (run: edge-tts --list-voices | grep en-US)
TTS_VOICE=en-US-AriaNeural

# Only needed for cloud providers:
# ELEVENLABS_API_KEY=your-elevenlabs-key
# TTS_VOICE_ID=21m00Tcm4TlvDq8ikWAM   # ElevenLabs default voice
# TTS_MODEL=eleven_turbo_v2_5

# ── Storage ─────────────────────────────────────────────────
CHROMA_DB_PATH=./data/chroma_db
